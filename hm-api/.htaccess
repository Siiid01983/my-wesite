# Hello Moving API — Apache config (cPanel)

# Protect secrets and internal files (prefixed with _ are include-only, never called directly)
<FilesMatch "^(_config\.php|_db\.php|_lib\.php|_log\.php|_cache\.php|_ratelimit\.php|_admin_users\.php|_config\.example\.php|schema\.mysql\.sql|admin_users\.schema\.sql)$">
  Require all denied
</FilesMatch>

# Never serve raw log files (they carry client IPs / User-Agents)
<FilesMatch "\.log(\.[0-9]+)?$">
  Require all denied
</FilesMatch>

# Block direct browsing of the uploads directory listing
Options -Indexes

# Endpoints are called directly by their filename:
#   <API_BASE>/rest.php  ·  /create-booking.php  ·  /get-booking.php  ·  /auth.php
#   /send-email.php  ·  /receive-email.php  ·  /storage.php
# CORS-safe headers are emitted by PHP (_lib.php hm_cors()).
