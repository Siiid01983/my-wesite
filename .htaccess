# ── Canonical host: force www → non-www (https://hello-moving.com) ───────────
# Keeps every visitor on a single origin so the same-origin API (/hm-api) is
# never cross-origin. Must run before anything else.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^www\.hello-moving\.com$ [NC]
  RewriteRule ^(.*)$ https://hello-moving.com/$1 [R=301,L]
</IfModule>

# ── Service worker — must never be cached by the server ──────────────────────
# Browsers check for SW script changes on every navigation. If the server
# caches sw.js, browsers never see the new cache-version stamp and stale
# assets persist indefinitely.
<IfModule mod_headers.c>
  <Files "sw.js">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>

  # HTML pages — always revalidate so index.html updates are immediate
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # CSS / JS — always revalidate (no-cache) so a deploy is reflected within ONE
  # reload, never up to an hour late. "no-cache" still stores the file and uses a
  # conditional request (ETag/Last-Modified) → cheap 304 when unchanged, full body
  # only when the asset actually changed. The SW (cache-first, version-namespaced)
  # still serves these instantly for controlled/offline clients on top of this.
  # NB: sw.js is excluded here so the dedicated no-store rule above wins for it.
  <FilesMatch "^(?!sw\.js$).*\.(css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Fallback: mod_expires for servers without mod_headers
<IfModule mod_expires.c>
  ExpiresActive On
  <FilesMatch "sw\.js$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>
</IfModule>

# ETags — fingerprint by mtime + size (works without mod_headers)
FileETag MTime Size
